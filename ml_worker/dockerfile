# ── Stage 1: Builder ──────────────────────────────────────────────────────────
# Install dependencies separately so they get cached by Docker.
# If only code changes, this layer is reused — no reinstall needed.
FROM python:3.12-slim AS builder

WORKDIR /app

# System deps needed to build some Python packages (nudenet, pillow etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libglib2.0-0 \
    libgl1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt


# ── Stage 2: Runtime ──────────────────────────────────────────────────────────
# Clean image — only what's needed to run, no build tools
FROM python:3.12-slim

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /install /usr/local

# Runtime system libs (same as builder but no gcc)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
    libgl1 \
    && rm -rf /var/lib/apt/lists/*

# Copy source code
COPY . .

# Don't run as root
RUN useradd -m worker
USER worker

# Environment defaults (override via docker run -e or docker-compose)
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    GEMINI_API_KEY="" \
    REDIS_URL="redis://localhost:6379"

CMD ["python", "worker.py"]